  {
    "filename": "esercizi/preposizioni-articolate/01.mp3",
    "text": "Il pinguino cammina sul ghiaccio."
  },
  {
    "filename": "esercizi/preposizioni-articolate/02.mp3",
    "text": "Marco gioca al parco con gli amici."
  },
  {
    "filename": "esercizi/preposizioni-articolate/03.mp3",
    "text": "Il libro è nello zaino."
  },
  {
    "filename": "esercizi/preposizioni-articolate/04.mp3",
    "text": "Il gatto dorme sul divano."
  },
  {
    "filename": "esercizi/preposizioni-articolate/05.mp3",
    "text": "Il pesce nuota nel mare."
  },
  {
    "filename": "esercizi/preposizioni-articolate/06.mp3",
    "text": "Questa è la casa del nonno."
  },
  {
    "filename": "esercizi/preposizioni-articolate/07.mp3",
    "text": "Oggi vado dalla nonna."
  },
  {
    "filename": "esercizi/preposizioni-articolate/08.mp3",
    "text": "L'uccello canta sull' albero."
  },
