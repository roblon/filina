  { "filename": "esercizi/avverbi/05.mp3", "text": "Marco raramente arriva in orario." },
  { "filename": "esercizi/avverbi/06.mp3", "text": "Spesso vado a correre nel parco." },
  { "filename": "esercizi/avverbi/07.mp3", "text": "Non ho mai visitato Roma." },
